<Window x:Class="MonitorDock.Windows.ControlPanelWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:MonitorDock.Converters"
        Title="MonitorDock - Control Panel"
        Width="750" Height="500"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip">
    <Window.Resources>
        <converters:PathToIconConverter x:Key="IconConverter"/>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Monitor list -->
            <GroupBox Header="Monitors" Grid.Column="0" Margin="0,0,6,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <ListBox x:Name="MonitorList" Grid.Row="0"
                             SelectionChanged="MonitorList_SelectionChanged"
                             DisplayMemberPath="DisplayName"/>
                    <CheckBox x:Name="MonitorEnabledCheck" Grid.Row="1" Margin="4,8,0,0"
                              Content="Enable dock on this monitor"
                              Checked="MonitorEnabledCheck_Changed"
                              Unchecked="MonitorEnabledCheck_Changed"/>
                </Grid>
            </GroupBox>

            <!-- Pinned apps for selected monitor -->
            <GroupBox Header="Pinned Apps" Grid.Column="1" Margin="6,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <ListBox x:Name="AppList" Grid.Row="0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="4">
                                    <Image Source="{Binding Path, Converter={StaticResource IconConverter}}"
                                           Width="32" Height="32" Margin="0,0,10,0"
                                           RenderOptions.BitmapScalingMode="HighQuality"/>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="13"/>
                                        <TextBlock Text="{Binding Path}" FontSize="11" Foreground="Gray"
                                                   TextTrimming="CharacterEllipsis" MaxWidth="380"/>
                                    </StackPanel>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <StackPanel Grid.Row="1" Orientation="Horizontal"
                                HorizontalAlignment="Right" Margin="0,8,0,0">
                        <Button Content="Add App..." Padding="14,5" Margin="4,0"
                                Click="AddApp_Click"/>
                        <Button Content="Remove" Padding="14,5" Margin="4,0"
                                Click="RemoveApp_Click"/>
                        <Button Content="Move Up" Padding="14,5" Margin="4,0"
                                Click="MoveUp_Click"/>
                        <Button Content="Move Down" Padding="14,5" Margin="4,0"
                                Click="MoveDown_Click"/>
                    </StackPanel>
                </Grid>
            </GroupBox>
        </Grid>

        <!-- Appearance settings -->
        <GroupBox Grid.Row="1" Header="Appearance" Margin="0,10,0,0">
            <Grid Margin="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="50"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Bar Height"
                           VerticalAlignment="Center"/>
                <Slider Grid.Row="0" Grid.Column="1" x:Name="BarHeightSlider"
                        Minimum="32" Maximum="72" TickFrequency="4" IsSnapToTickEnabled="True"
                        ValueChanged="BarHeightSlider_ValueChanged"/>
                <TextBlock Grid.Row="0" Grid.Column="2" x:Name="BarHeightLabel"
                           VerticalAlignment="Center" HorizontalAlignment="Center"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Icon Size"
                           VerticalAlignment="Center"/>
                <Slider Grid.Row="2" Grid.Column="1" x:Name="IconSizeSlider"
                        Minimum="16" Maximum="48" TickFrequency="4" IsSnapToTickEnabled="True"
                        ValueChanged="IconSizeSlider_ValueChanged"/>
                <TextBlock Grid.Row="2" Grid.Column="2" x:Name="IconSizeLabel"
                           VerticalAlignment="Center" HorizontalAlignment="Center"/>
            </Grid>
        </GroupBox>

        <!-- Behavior settings -->
        <GroupBox Grid.Row="2" Header="Behavior" Margin="0,10,0,0">
            <StackPanel Margin="8">
                <CheckBox x:Name="ClickFocusedMinimizesCheck"
                          Content="Clicking a focused app minimizes it"/>
                <CheckBox x:Name="HideSecondaryTaskbarsCheck" Margin="0,6,0,0"
                          Content="Hide Windows taskbar on secondary monitors"/>
                <CheckBox x:Name="StartWithWindowsCheck" Margin="0,6,0,0"
                          Content="Start MonitorDock with Windows"/>
            </StackPanel>
        </GroupBox>

        <!-- Dialog buttons -->
        <StackPanel Grid.Row="3" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Restart MonitorDock" Padding="14,6" Margin="4,0"
                    Click="Restart_Click" Foreground="#CC0000" HorizontalAlignment="Left"/>
            <Button Content="Save" Padding="24,6" Margin="4,0"
                    Click="Save_Click" IsDefault="True" FontWeight="SemiBold"/>
            <Button Content="Cancel" Padding="24,6" Margin="4,0"
                    Click="Cancel_Click" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
